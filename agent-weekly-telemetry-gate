#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: $0 <repo_path> [window_days] [claude_home] [events_file]" >&2
  exit 1
fi

AGENTKIT_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$1" && pwd)"
WINDOW_DAYS="${2:-7}"
CLAUDE_HOME="${3:-$HOME/.claude}"
EVENTS_FILE="${4:-${AGENTKIT_BIN}/.claude/agent-events.jsonl}"
STRICT_JSON="${REPO_ROOT}/.claude/telemetry-strict.json"
WEEKLY_MD="${REPO_ROOT}/.claude/telemetry-weekly.md"

mkdir -p "${REPO_ROOT}/.claude"

echo "[agent-weekly-telemetry-gate] running strict checker..."
STRICT_EXIT=0
"${AGENTKIT_BIN}/agent-telemetry-strict" \
  --repo "${REPO_ROOT}" \
  --claude-home "${CLAUDE_HOME}" \
  --events "${EVENTS_FILE}" \
  --window-days "${WINDOW_DAYS}" \
  --json \
  --out "${STRICT_JSON}" \
  --enforce || STRICT_EXIT=$?

echo "[agent-weekly-telemetry-gate] running telemetry ingest..."
"${AGENTKIT_BIN}/agent-telemetry" ingest \
  --repo "${REPO_ROOT}" \
  --claude-home "${CLAUDE_HOME}" \
  --events "${EVENTS_FILE}"

echo "[agent-weekly-telemetry-gate] regenerating weekly summary..."
"${AGENTKIT_BIN}/agent-telemetry" weekly-summary \
  --repo "${REPO_ROOT}" \
  --window-days "${WINDOW_DAYS}" \
  --out "${WEEKLY_MD}"

if [[ "${STRICT_EXIT}" -ne 0 ]]; then
  echo "[agent-weekly-telemetry-gate] ALERT: strict telemetry check failed with exit ${STRICT_EXIT}. Alert-only mode keeps exit code 0."
  exit 0
fi

echo "[agent-weekly-telemetry-gate] strict telemetry passed."
