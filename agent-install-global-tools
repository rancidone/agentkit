#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN_DIR="${1:-$HOME/.local/bin}"

echo "agent-install-global-tools is deprecated; using manifest-managed install plus legacy wrapper links." >&2
exec python3 "${SCRIPT_DIR}/agent-install" --repo-root "${SCRIPT_DIR}" --legacy-bin-dir "${BIN_DIR}"
