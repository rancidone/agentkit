#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "agent-install-global-tools is deprecated; wrapper symlink installation is no longer the default." >&2
if [[ $# -gt 0 ]]; then
  echo "Ignoring legacy bin-dir argument: $1" >&2
fi
exec python3 "${SCRIPT_DIR}/agent-install" --repo-root "${SCRIPT_DIR}"
