#!/usr/bin/env bash
set -euo pipefail

MESSAGE_FILE=""
FILES=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --message-file)
      MESSAGE_FILE="$2"
      shift 2
      ;;
    --files)
      shift
      while [[ $# -gt 0 ]]; do
        FILES+=("$1")
        shift
      done
      ;;
    *)
      echo "Unknown arg: $1" >&2
      exit 1
      ;;
  esac
done

if [[ -z "$MESSAGE_FILE" ]]; then
  echo "--message-file is required" >&2
  exit 1
fi
if [[ ! -f "$MESSAGE_FILE" ]]; then
  echo "message file not found: $MESSAGE_FILE" >&2
  exit 1
fi

if [[ ${#FILES[@]} -eq 0 ]]; then
  git add -A
else
  git add -- "${FILES[@]}"
fi

git commit --file "$MESSAGE_FILE"
