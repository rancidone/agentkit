#!/usr/bin/env python3
"""agent-log - append a JSONL event to the agent events log.

Usage:
  agent-log --events <path> --event-type <type> [--field key=value ...]
"""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import sys


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(prog="agent-log")
    parser.add_argument("--events", required=True)
    parser.add_argument("--event-type", required=True)
    parser.add_argument("--field", action="append", default=[])
    return parser.parse_args()


def parse_field(raw: str) -> tuple[str, str]:
    if "=" not in raw:
        raise ValueError(f"invalid --field '{raw}': expected key=value")
    key, value = raw.split("=", 1)
    key = key.strip()
    if not key:
        raise ValueError(f"invalid --field '{raw}': key cannot be empty")
    return key, value


def main() -> int:
    args = parse_args()

    payload: dict[str, str] = {
        "event_type": args.event_type,
        "timestamp": dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    }

    try:
        for raw in args.field:
            k, v = parse_field(raw)
            payload[k] = v
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 1

    events_file = args.events
    events_dir = os.path.dirname(events_file) or "."
    os.makedirs(events_dir, exist_ok=True)

    with open(events_file, "a", encoding="utf-8") as fh:
        fh.write(json.dumps(payload, ensure_ascii=False) + "\n")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
