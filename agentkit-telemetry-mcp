#!/usr/bin/env python3
"""Telemetry-facing MCP stdio server."""

from __future__ import annotations

import argparse
import json
import os
from typing import Any

from agent_telemetry_backend import (
    append_event,
    hotspots_telemetry,
    ingest_telemetry,
    inspect_telemetry,
    inspect_task_run,
    migrate_telemetry,
    report_telemetry,
    trend_telemetry,
    tui_snapshot,
    tui_task_detail,
)
from agentkit_common import repo_root
from agentkit_mcp import describe_service
from agentkit_mcp_server import ToolDefinition, run_stdio_server


def _events_path(repo: str, arguments: dict[str, Any]) -> str:
    events = str(arguments.get("events", ".claude/agent-events.jsonl"))
    return events if os.path.isabs(events) else os.path.join(repo, events)


def _task_event(arguments: dict[str, Any], event_type: str, status: str | None = None) -> dict[str, Any]:
    repo = repo_root(str(arguments.get("repo", ".")))
    fields = {
        "repo": repo,
        "task_id": arguments.get("task_id"),
        "session_branch": arguments.get("session_branch"),
        "task_text": arguments.get("task_text"),
        "complexity_points": arguments.get("complexity_points"),
        "status": arguments.get("status", status),
    }
    return append_event(_events_path(repo, arguments), event_type, fields)


def _handle_ingest(arguments: dict[str, Any]) -> dict[str, Any]:
    repo = repo_root(str(arguments.get("repo", ".")))
    return ingest_telemetry(
        repo,
        str(arguments.get("claude_home", os.path.expanduser("~/.claude"))),
        str(arguments.get("codex_home", os.path.expanduser("~/.codex"))),
        _events_path(repo, arguments),
    )


def _handle_migrate(arguments: dict[str, Any]) -> dict[str, Any]:
    repo = repo_root(str(arguments.get("repo", ".")))
    extra_events = [
        path if os.path.isabs(path) else os.path.join(repo, path)
        for path in arguments.get("extra_events", []) or []
    ]
    return migrate_telemetry(
        repo,
        str(arguments.get("claude_home", os.path.expanduser("~/.claude"))),
        str(arguments.get("codex_home", os.path.expanduser("~/.codex"))),
        _events_path(repo, arguments),
        extra_events,
    )


def _handle_report(arguments: dict[str, Any]) -> dict[str, Any]:
    repo = repo_root(str(arguments.get("repo", ".")))
    return report_telemetry(repo, int(arguments.get("window_days", 7)), arguments.get("since"))


def _handle_hotspots(arguments: dict[str, Any]) -> dict[str, Any]:
    repo = repo_root(str(arguments.get("repo", ".")))
    return hotspots_telemetry(
        repo,
        int(arguments.get("window_days", 7)),
        arguments.get("since"),
        int(arguments.get("limit", 12)),
        int(arguments.get("warn_avg_tokens", 25000)),
    )


def _handle_trend(arguments: dict[str, Any]) -> dict[str, Any]:
    repo = repo_root(str(arguments.get("repo", ".")))
    return trend_telemetry(repo, int(arguments.get("window_days", 30)), arguments.get("since"))


def _handle_inspect(arguments: dict[str, Any]) -> dict[str, Any]:
    repo = repo_root(str(arguments.get("repo", ".")))
    return inspect_telemetry(repo)


def _handle_task_inspect(arguments: dict[str, Any]) -> dict[str, Any]:
    repo = repo_root(str(arguments.get("repo", ".")))
    task_id = str(arguments.get("task_id", "")).strip()
    if not task_id:
        raise SystemExit("task_id is required")
    return inspect_task_run(repo, task_id)


def _handle_tui_snapshot(arguments: dict[str, Any]) -> dict[str, Any]:
    repo = repo_root(str(arguments.get("repo", ".")))
    provider = arguments.get("provider")
    provider_filter = None if provider in (None, "") else str(provider)
    task_outcome = arguments.get("task_outcome")
    outcome_filter = None if task_outcome in (None, "") else str(task_outcome)
    search_text = arguments.get("search_text")
    search_filter = None if search_text in (None, "") else str(search_text)
    complexity_min = arguments.get("complexity_min")
    complexity_max = arguments.get("complexity_max")
    return tui_snapshot(
        repo,
        int(arguments.get("window_days", 7)),
        arguments.get("since"),
        hotspot_limit=int(arguments.get("hotspot_limit", 12)),
        warn_avg_tokens=int(arguments.get("warn_avg_tokens", 25000)),
        task_limit=int(arguments.get("task_limit", 50)),
        provider=provider_filter,
        task_outcome=outcome_filter,
        search_text=search_filter,
        complexity_min=int(complexity_min) if complexity_min is not None else None,
        complexity_max=int(complexity_max) if complexity_max is not None else None,
    )


def _handle_tui_task_detail(arguments: dict[str, Any]) -> dict[str, Any]:
    repo = repo_root(str(arguments.get("repo", ".")))
    task_id = str(arguments.get("task_id", "")).strip()
    if not task_id:
        raise SystemExit("task_id is required")
    return tui_task_detail(repo, task_id)


def _tools() -> list[ToolDefinition]:
    return [
        ToolDefinition(
            "telemetry.migrate",
            "Upgrade a legacy telemetry DB in place and merge current telemetry sources.",
            {
                "type": "object",
                "properties": {
                    "repo": {"type": "string"},
                    "claude_home": {"type": "string"},
                    "codex_home": {"type": "string"},
                    "events": {"type": "string"},
                    "extra_events": {
                        "type": "array",
                        "items": {"type": "string"},
                    },
                },
            },
            _handle_migrate,
        ),
        ToolDefinition(
            "telemetry.ingest",
            "Ingest usage logs and task events into telemetry state.",
            {
                "type": "object",
                "properties": {
                    "repo": {"type": "string"},
                    "claude_home": {"type": "string"},
                    "codex_home": {"type": "string"},
                    "events": {"type": "string"},
                },
            },
            _handle_ingest,
        ),
        ToolDefinition(
            "telemetry.report",
            "Return telemetry summary metrics for a repo.",
            {
                "type": "object",
                "properties": {
                    "repo": {"type": "string"},
                    "window_days": {"type": "integer"},
                    "since": {"type": "string"},
                },
            },
            _handle_report,
        ),
        ToolDefinition(
            "telemetry.hotspots",
            "Return tool hotspots and token warnings.",
            {
                "type": "object",
                "properties": {
                    "repo": {"type": "string"},
                    "window_days": {"type": "integer"},
                    "since": {"type": "string"},
                    "limit": {"type": "integer"},
                    "warn_avg_tokens": {"type": "integer"},
                },
            },
            _handle_hotspots,
        ),
        ToolDefinition(
            "telemetry.trend",
            "Return day-by-day telemetry trend points.",
            {
                "type": "object",
                "properties": {
                    "repo": {"type": "string"},
                    "window_days": {"type": "integer"},
                    "since": {"type": "string"},
                },
            },
            _handle_trend,
        ),
        ToolDefinition(
            "telemetry.inspect",
            "Inspect telemetry DB counts and ingest checkpoints.",
            {"type": "object", "properties": {"repo": {"type": "string"}}},
            _handle_inspect,
        ),
        ToolDefinition(
            "task.inspect",
            "Inspect the runs and lifecycle events recorded for a task_id.",
            {
                "type": "object",
                "properties": {
                    "repo": {"type": "string"},
                    "task_id": {"type": "string"},
                },
            },
            _handle_task_inspect,
        ),
        ToolDefinition(
            "tui.snapshot",
            "Return read-only telemetry models for the TUI summary, trends, hotspots, inspect, and task-run views.",
            {
                "type": "object",
                "properties": {
                    "repo": {"type": "string"},
                    "window_days": {"type": "integer"},
                    "since": {"type": "string"},
                    "provider": {"type": "string"},
                    "task_outcome": {"type": "string"},
                    "search_text": {"type": "string"},
                    "complexity_min": {"type": "integer"},
                    "complexity_max": {"type": "integer"},
                    "task_limit": {"type": "integer"},
                    "hotspot_limit": {"type": "integer"},
                    "warn_avg_tokens": {"type": "integer"},
                },
            },
            _handle_tui_snapshot,
        ),
        ToolDefinition(
            "tui.task_detail",
            "Return read-only task detail for a TUI drill-down by task_id.",
            {
                "type": "object",
                "properties": {
                    "repo": {"type": "string"},
                    "task_id": {"type": "string"},
                },
            },
            _handle_tui_task_detail,
        ),
        ToolDefinition(
            "task.log_started",
            "Append a task_started event to the repo event log.",
            {
                "type": "object",
                "properties": {
                    "repo": {"type": "string"},
                    "task_id": {"type": "string"},
                    "session_branch": {"type": "string"},
                    "task_text": {"type": "string"},
                    "complexity_points": {"type": "integer"},
                    "events": {"type": "string"},
                },
            },
            lambda arguments: _task_event(arguments, "task_started"),
        ),
        ToolDefinition(
            "task.log_completed",
            "Append a task_completed event to the repo event log.",
            {
                "type": "object",
                "properties": {
                    "repo": {"type": "string"},
                    "task_id": {"type": "string"},
                    "session_branch": {"type": "string"},
                    "events": {"type": "string"},
                },
            },
            lambda arguments: _task_event(arguments, "task_completed"),
        ),
        ToolDefinition(
            "task.log_failed",
            "Append a task_failed event to the repo event log.",
            {
                "type": "object",
                "properties": {
                    "repo": {"type": "string"},
                    "task_id": {"type": "string"},
                    "session_branch": {"type": "string"},
                    "status": {"type": "string"},
                    "events": {"type": "string"},
                },
            },
            lambda arguments: _task_event(arguments, "task_failed", "failed"),
        ),
        ToolDefinition(
            "task.log_worker_spawned",
            "Append a worker_spawned event to the repo event log.",
            {
                "type": "object",
                "properties": {
                    "repo": {"type": "string"},
                    "task_id": {"type": "string"},
                    "session_branch": {"type": "string"},
                    "events": {"type": "string"},
                },
            },
            lambda arguments: _task_event(arguments, "worker_spawned"),
        ),
        ToolDefinition(
            "task.log_worker_merged",
            "Append a worker_merged event to the repo event log.",
            {
                "type": "object",
                "properties": {
                    "repo": {"type": "string"},
                    "task_id": {"type": "string"},
                    "session_branch": {"type": "string"},
                    "status": {"type": "string"},
                    "events": {"type": "string"},
                },
            },
            lambda arguments: _task_event(arguments, "worker_merged", "merged"),
        ),
    ]


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run the agentkit telemetry MCP server.")
    parser.add_argument("--describe", action="store_true", default=False)
    return parser.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv)
    if args.describe:
        print(json.dumps(describe_service("agentkit-telemetry-mcp"), indent=2))
        return 0
    return run_stdio_server("agentkit-telemetry-mcp", "0.1.0", _tools())


if __name__ == "__main__":
    raise SystemExit(main())
