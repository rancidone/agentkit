#!/usr/bin/env python3
"""Bootstrap entrypoint for the repo-facing MCP service split."""

from __future__ import annotations

import json

from agentkit_mcp import describe_service


def main() -> int:
    print(json.dumps(describe_service("agentkit-repo-mcp"), indent=2))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
