#!/usr/bin/env python3
"""High-level orchestration CLI for agentkit workflows."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import tempfile
from typing import Any

from agentkit_common import detect_runner, repo_root


def _run_tool(script_name: str, args: list[str]) -> dict[str, Any]:
    script_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), script_name)
    cmd = [sys.executable, script_path, *args]
    proc = subprocess.run(cmd, capture_output=True, text=True, check=False)

    if proc.returncode != 0:
        raise SystemExit(
            json.dumps(
                {
                    "tool": script_name,
                    "command": cmd,
                    "exit_code": proc.returncode,
                    "stderr": proc.stderr.strip(),
                    "stdout": proc.stdout.strip(),
                },
                indent=2,
            )
        )

    output = (proc.stdout or "").strip()
    if not output:
        return {"ok": True}

    try:
        return json.loads(output)
    except json.JSONDecodeError:
        return {"raw": output}


def _telemetry_ingest_args(
    repo: str,
    claude_home: str,
    codex_home: str,
    events: str | None,
) -> tuple[list[str], tempfile.TemporaryDirectory[str] | None]:
    scope = detect_runner()
    tmpdir: tempfile.TemporaryDirectory[str] | None = None

    if scope == "codex":
        tmpdir = tempfile.TemporaryDirectory(prefix="agentkit-empty-claude-")
        claude_home = tmpdir.name
    elif scope == "claude":
        tmpdir = tempfile.TemporaryDirectory(prefix="agentkit-empty-codex-")
        codex_home = tmpdir.name

    ingest_args = [
        "ingest",
        "--repo",
        repo,
        "--claude-home",
        claude_home,
        "--codex-home",
        codex_home,
    ]
    if events:
        ingest_args.extend(["--events", events])
    return ingest_args, tmpdir


def cmd_prepare(args: argparse.Namespace) -> int:
    repo = repo_root(args.repo)
    index = _run_tool("agent-index", ["build", "--repo", repo, "--mode", args.mode])
    pack_args = [
        "pack",
        "--repo",
        repo,
        "--task",
        args.task,
        "--limit",
        str(args.limit),
        "--token-budget",
        str(args.token_budget),
    ]
    if args.out:
        pack_args.extend(["--out", args.out])
    pack = _run_tool("agent-index", pack_args)

    print(
        json.dumps(
            {
                "repo": repo,
                "phase": "prepare",
                "index": index,
                "pack": pack,
            },
            indent=2,
        )
    )
    return 0


def cmd_observe(args: argparse.Namespace) -> int:
    repo = repo_root(args.repo)
    events = args.events
    if events and not os.path.isabs(events):
        events = os.path.join(repo, events)

    ingest_args, tmpdir = _telemetry_ingest_args(repo, args.claude_home, args.codex_home, events)
    try:
        ingest = _run_tool("agent-telemetry", ingest_args)
    finally:
        if tmpdir is not None:
            tmpdir.cleanup()
    report = _run_tool("agent-telemetry", ["report", "--repo", repo, "--window-days", str(args.window_days)])
    hotspots = _run_tool(
        "agent-telemetry",
        [
            "hotspots",
            "--repo",
            repo,
            "--window-days",
            str(args.window_days),
            "--limit",
            str(args.hotspot_limit),
        ],
    )

    print(
        json.dumps(
            {
                "repo": repo,
                "phase": "observe",
                "ingest": ingest,
                "report": report,
                "hotspots": hotspots,
            },
            indent=2,
        )
    )
    return 0


def cmd_cycle(args: argparse.Namespace) -> int:
    repo = repo_root(args.repo)
    index = _run_tool("agent-index", ["build", "--repo", repo, "--mode", args.mode])

    pack_args = [
        "pack",
        "--repo",
        repo,
        "--task",
        args.task,
        "--limit",
        str(args.limit),
        "--token-budget",
        str(args.token_budget),
    ]
    if args.out:
        pack_args.extend(["--out", args.out])
    pack = _run_tool("agent-index", pack_args)

    events = args.events
    if events and not os.path.isabs(events):
        events = os.path.join(repo, events)
    ingest_args, tmpdir = _telemetry_ingest_args(repo, args.claude_home, args.codex_home, events)
    try:
        ingest = _run_tool("agent-telemetry", ingest_args)
    finally:
        if tmpdir is not None:
            tmpdir.cleanup()
    report = _run_tool("agent-telemetry", ["report", "--repo", repo, "--window-days", str(args.window_days)])

    print(
        json.dumps(
            {
                "repo": repo,
                "phase": "cycle",
                "prepare": {"index": index, "pack": pack},
                "observe": {"ingest": ingest, "report": report},
            },
            indent=2,
        )
    )
    return 0


def parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="agentkit", description="Orchestrate agent-index and agent-telemetry.")
    sp = p.add_subparsers(dest="cmd", required=True)

    p_prepare = sp.add_parser("prepare", help="Build index and generate a task context pack.")
    p_prepare.add_argument("--repo", default=".")
    p_prepare.add_argument("--mode", choices=["full", "light"], default="light")
    p_prepare.add_argument("--task", required=True)
    p_prepare.add_argument("--limit", type=int, default=12)
    p_prepare.add_argument("--token-budget", type=int, default=2800)
    p_prepare.add_argument("--out")
    p_prepare.set_defaults(func=cmd_prepare)

    p_observe = sp.add_parser("observe", help="Ingest telemetry and produce usage summaries.")
    p_observe.add_argument("--repo", default=".")
    p_observe.add_argument("--claude-home", default=os.path.expanduser("~/.claude"))
    p_observe.add_argument("--codex-home", default=os.path.expanduser("~/.codex"))
    p_observe.add_argument("--events", default=".claude/agent-events.jsonl")
    p_observe.add_argument("--window-days", type=int, default=7)
    p_observe.add_argument("--hotspot-limit", type=int, default=12)
    p_observe.set_defaults(func=cmd_observe)

    p_cycle = sp.add_parser("cycle", help="Run a full prepare+observe orchestration cycle.")
    p_cycle.add_argument("--repo", default=".")
    p_cycle.add_argument("--mode", choices=["full", "light"], default="light")
    p_cycle.add_argument("--task", required=True)
    p_cycle.add_argument("--limit", type=int, default=12)
    p_cycle.add_argument("--token-budget", type=int, default=2800)
    p_cycle.add_argument("--out")
    p_cycle.add_argument("--claude-home", default=os.path.expanduser("~/.claude"))
    p_cycle.add_argument("--codex-home", default=os.path.expanduser("~/.codex"))
    p_cycle.add_argument("--events", default=".claude/agent-events.jsonl")
    p_cycle.add_argument("--window-days", type=int, default=7)
    p_cycle.add_argument("--hotspot-limit", type=int, default=12)
    p_cycle.set_defaults(func=cmd_cycle)

    return p


def main() -> int:
    args = parser().parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
